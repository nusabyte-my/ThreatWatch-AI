{
  "manifest_version": 3,
  "name": "ThreatWatch AI for Outlook Web",
  "version": "0.1.0",
  "description": "Scans open Outlook Web messages with ThreatWatch AI and shows an in-page verdict badge.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://outlook.office.com/*",
    "https://outlook.live.com/*",
    "http://localhost:8100/*",
    "https://threatwatch-ai-api.up.railway.app/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.live.com/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
