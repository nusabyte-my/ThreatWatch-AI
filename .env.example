# --- Database ---
# Local (docker-compose)
DB_PASSWORD=threatwatch_secret

# Supabase (production) — replace with your project values
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- App ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_replace_with_64_char_random_hex

# ML model path (container path)
MODEL_PATH=/app/ml/model.pkl

# --- CORS ---
# Comma-separated list of allowed origins
# Local: http://localhost:3000
# Production: https://threatwatch-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://mail.google.com
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# --- Admin API Key ---
# Used to protect /api/v1/rules endpoints
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
API_KEY=changeme_api_key
MAX_REQUEST_BYTES=3145728

# --- Auth / RBAC ---
# Minimal bootstrap users for local/dev. Use strong passwords and restrict roles in production.
# Format: [{"username":"admin","password":"strong-password","role":"admin"},{"username":"analyst","password":"strong-password","role":"analyst"}]
AUTH_ENABLED=true
AUTH_TOKEN_TTL_MINUTES=480
AUTH_USERS_JSON=[{"username":"admin","password":"changeme_admin_password","role":"admin"}]

# --- Agent Pipeline ---
# Primary LLM (gpt-4o for demo, gpt-4o-mini for dev to save cost)
AGENT_PRIMARY_MODEL=gpt-4o-mini
AGENT_PIPELINE_ENABLED=true
AGENT_LLM_TIMEOUT=15
AGENT_MAX_TOKENS=512

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic — Claude Haiku fallback — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Ollama / local models — optional self-hosted assistant path
# Example model: gemma4:e2b, llama3.1:8b
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT=75

# Google Safe Browsing — optional URL reputation signal
# Get from: https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=
GOOGLE_SAFE_BROWSING_TIMEOUT=5

# --- Debug ---
DEBUG=false
