# --- Database ---
# Local (docker-compose)
DB_PASSWORD=threatwatch_secret

# Supabase (production) — replace with your project values
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- App ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_replace_with_64_char_random_hex

# ML model path (container path)
MODEL_PATH=/app/ml/model.pkl

# --- CORS ---
# Comma-separated list of allowed origins
# Local: http://localhost:3000
# Production: https://threatwatch-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Admin API Key ---
# Used to protect /api/v1/rules endpoints
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
API_KEY=changeme_api_key

# --- Agent Pipeline ---
# Primary LLM (gpt-4o for demo, gpt-4o-mini for dev to save cost)
AGENT_PRIMARY_MODEL=gpt-4o-mini
AGENT_PIPELINE_ENABLED=true
AGENT_LLM_TIMEOUT=15
AGENT_MAX_TOKENS=512

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Anthropic — Claude Haiku fallback — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Debug ---
DEBUG=false
