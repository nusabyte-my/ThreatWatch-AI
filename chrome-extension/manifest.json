{
  "manifest_version": 3,
  "name": "ThreatWatch AI for Gmail",
  "version": "0.1.0",
  "description": "Scans open Gmail messages with ThreatWatch AI and shows an in-page scam verdict badge.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8100/*",
    "https://threatwatch-ai.nusabyte.cloud/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
