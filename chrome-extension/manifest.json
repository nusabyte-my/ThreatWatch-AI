{
  "manifest_version": 3,
  "name": "ThreatWatch AI for Gmail",
  "version": "0.1.0",
  "description": "Scans open Gmail messages with ThreatWatch AI and shows an in-page scam verdict badge.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8100/*",
    "https://threatwatch-ai-api.up.railway.app/*"
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
